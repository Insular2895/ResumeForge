# ============================================================
# GEMINI API (optionnel — désactiver si non utilisé)
# ============================================================

# Mettre true pour activer l'optimisation Gemini, false pour désactiver
USE_GEMINI=true

# Clé API Gemini → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modèles en rotation (1 CV = 1 appel, rotation automatique)
# 3 modèles × 20 appels/jour = 60 CV optimisés par jour
GEMINI_ROTATION_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.5-flash-preview-05-20
GEMINI_DAILY_LIMIT_PER_MODEL=20

# ============================================================
# GOOGLE SHEETS (optionnel — pour le suivi des candidatures)
# ============================================================

# ID du Google Sheet → dans l'URL : docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Nom de l'onglet dans le Google Sheet (laisser "applications" par défaut)
GOOGLE_SHEET_TAB=applications

# ============================================================
# CACHE / REDIS (optionnel — mode SaaS uniquement)
# ============================================================

# Provider : "memory" (défaut, fonctionne sans Redis) ou "redis"
CACHE_PROVIDER=memory

# Redis standard (si CACHE_PROVIDER=redis)
REDIS_URL=

# Upstash Redis via REST API (serverless / edge — recommandé pour Supabase Edge Functions)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# TTL par défaut des entrées cache en secondes (3600 = 1h)
CACHE_DEFAULT_TTL_SECONDS=3600
