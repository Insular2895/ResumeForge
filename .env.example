# ============================================================
# GEMINI API (optionnel — désactiver si non utilisé)
# ============================================================

# Mettre true pour activer l'optimisation Gemini, false pour désactiver
USE_GEMINI=true

# Clé API Gemini → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Clé dédiée à la génération de lettre de motivation.
# Si elle est absente, run_application.py génère le CV + CV Markdown
# puis marque la LM comme skipped proprement.
GEMINI_LETTER_API_KEY=your_gemini_letter_api_key_here
GEMINI_LETTER_MODEL=gemini-3.1-flash-lite
GEMINI_LETTER_FALLBACK_MODELS=gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-2.5-flash

# Clé dédiée à l'enrichissement de la base métier.
# Ne sert pas au CV ni à la LM. Utilisée seulement par le script manuel
# scripts/enrich_domain_vocabulary.py, sauf activation explicite future.
GEMINI_DOMAIN_API_KEY=your_gemini_domain_research_api_key_here
GEMINI_DOMAIN_MODEL=gemini-3.1-flash-lite
AUTO_ENRICH_DOMAIN_VOCABULARY=false

# Modèles en rotation (1 CV = 1 appel, rotation automatique)
# Gemini 3/3.1 d'abord, puis Gemini 2.5 en fallback.
GEMINI_ROTATION_MODELS=gemini-3.1-flash-lite,gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-2.5-flash

# Modèles candidats à réessayer automatiquement.
# Ils sont ignorés pour la journée s'ils répondent 404/429.
GEMINI_OPTIONAL_MODELS=gemini-2.0-flash
GEMINI_DAILY_LIMIT_PER_MODEL=20

# ============================================================
# GOOGLE SHEETS (optionnel — pour le suivi des candidatures)
# ============================================================

# ID du Google Sheet → dans l'URL : docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Nom de l'onglet dans le Google Sheet (laisser "applications" par défaut)
GOOGLE_SHEET_TAB=applications
